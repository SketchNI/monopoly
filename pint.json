{
    "preset": "laravel",
    "rules": {
        "not_operator_with_successor_space": false,
        "no_superfluous_phpdoc_tags": false,
        "phpdoc_trim": false,
        "no_trailing_whitespace_in_comment": false,
        "phpdoc_separation": {
            "groups": [
                [
                    "deprecated",
                    "link",
                    "see",
                    "since"
                ],
                [
                    "author"
                ],
                [
                    "param"
                ],
                [
                    "return"
                ]
            ]
        }
    }
}
